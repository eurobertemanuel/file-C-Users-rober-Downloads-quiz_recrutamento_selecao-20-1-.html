let session=[],cur=0,sc=0,chosen=null,playerName='';

function shuffle(a){let b=[...a];for(let i=b.length-1;i>0;i--){let j=Math.floor(Math.random()*(i+1));[b[i],b[j]]=[b[j],b[i]]}return b}

function setNav(id){
  document.querySelectorAll('.nav-link').forEach(n=>n.classList.remove('active'));
  const map={home:'nav-home',ranking:'nav-rank'};
  if(map[id])document.getElementById(map[id]).classList.add('active');
}

function showScreen(id){
  document.querySelectorAll('.screen').forEach(s=>s.classList.remove('active'));
  document.getElementById(id).classList.add('active');
  setNav(id);
  window.scrollTo(0,0);
}

function goRanking(){
  showScreen('ranking');
  loadRanking('full-rank',50);
}

function askName(){
  showScreen('name-screen');
  setNav('');
  setTimeout(()=>document.getElementById('player-name').focus(),100);
}

function confirmName(){
  const n=document.getElementById('player-name').value.trim();
  if(!n){document.getElementById('player-name').focus();return;}
  playerName=n;
  startQuiz();
}

function startQuiz(){
  session=shuffle(ALL_Q).slice(0,14);
  cur=0;sc=0;chosen=null;
  showScreen('quiz');
  setNav('');
  renderQ();
}

function renderQ(){
  const q=session[cur];
  document.getElementById('q-label').textContent='Questão '+(cur+1)+' / 14';
  document.getElementById('q-topic').textContent=q.t;
  document.getElementById('prog').style.width=Math.round((cur/14)*100)+'%';
  document.getElementById('q-text').textContent=q.q;
  document.getElementById('q-expl').style.display='none';
  document.getElementById('next-btn').style.display='none';
  document.getElementById('live-score').textContent=sc+' acerto'+(sc!==1?'s':'')+' até agora';
  const letters=['A','B','C','D'];
  const shuf=shuffle(q.opts.map((o,i)=>({o,i})));
  document.getElementById('opts').innerHTML=shuf.map((item,idx)=>`
    <div class="opt" onclick="pick(this,${item.i},${q.ans})" data-idx="${item.i}">
      <span class="letter">${letters[idx]}</span>
      <span>${item.o}</span>
    </div>`).join('');
  chosen=null;
}

function pick(el,idx,ans){
  if(chosen!==null)return;
  chosen=idx;
  document.querySelectorAll('.opt').forEach(o=>o.classList.add('disabled'));
  const q=session[cur];
  if(idx===ans){el.classList.add('correct');sc++;}
  else{
    el.classList.add('wrong');
    document.querySelectorAll('.opt').forEach(o=>{if(parseInt(o.dataset.idx)===ans)o.classList.add('correct');});
  }
  const expl=document.getElementById('q-expl');
  expl.textContent='💡 '+q.e;
  expl.style.display='block';
  document.getElementById('next-btn').style.display='inline-flex';
  document.getElementById('live-score').textContent=sc+' acerto'+(sc!==1?'s':'')+' até agora';
}

function nextQ(){
  cur++;
  if(cur>=14){finishQuiz();return;}
  renderQ();
}

async function saveToFirebase(entry){
  try{
    const res=await fetch(FIREBASE_URL+'/ranking.json',{
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body:JSON.stringify(entry)
    });
    return res.ok;
  }catch(e){return false;}
}

async function loadFromFirebase(){
  try{
    const res=await fetch(FIREBASE_URL+'/ranking.json');
    const data=await res.json();
    if(!data)return[];
    return Object.values(data);
  }catch(e){return[];}
}

async function finishQuiz(){
  const pct=Math.round((sc/14)*100);
  const now=new Date();
  const entry={
    name:playerName,
    score:sc,
    pct,
    date:now.toLocaleDateString('pt-BR'),
    time:now.toLocaleTimeString('pt-BR',{hour:'2-digit',minute:'2-digit'}),
    ts:now.getTime()
  };

  document.getElementById('score-num').textContent=sc+'/14';
  let msg=sc>=13?'🏆 Perfeito! Excelente domínio do conteúdo!':sc>=11?'🎉 Ótimo resultado! Continue assim!':sc>=9?'👍 Bom trabalho! Ainda há espaço para melhorar.':sc>=7?'📖 Regular. Revise os tópicos com mais atenção.':'💪 Revise o conteúdo e tente novamente!';
  document.getElementById('score-msg').textContent=msg;
  document.getElementById('b-acc').textContent='✓ '+sc+' acerto'+(sc!==1?'s':'');
  document.getElementById('b-err').textContent='✗ '+(14-sc)+' erro'+((14-sc)!==1?'s':'');
  document.getElementById('b-pct').textContent=pct+'% de aproveitamento';
  document.getElementById('st-acc').textContent=sc;
  document.getElementById('st-err').textContent=14-sc;
  document.getElementById('st-pct').textContent=pct+'%';
  showScreen('result');

  document.getElementById('save-status').textContent='💾 A guardar no ranking...';
  const ok=await saveToFirebase(entry);
  document.getElementById('save-status').textContent=ok?'✅ Guardado no ranking global!':'⚠️ Não foi possível guardar. Verifique a ligação.';
  loadRanking('result-rank',10);
}

async function loadRanking(containerId,limit){
  const el=document.getElementById(containerId);
  el.innerHTML='<div style="color:#888780;font-size:13px;padding:.5rem 0">A carregar ranking...</div>';
  const entries=await loadFromFirebase();
  if(!entries.length){
    el.innerHTML='<div class="empty">Ainda ninguém jogou. Sê o primeiro! 🚀</div>';
    return;
  }
  entries.sort((a,b)=>b.score-a.score||a.ts-b.ts);
  const shown=entries.slice(0,limit);
  const rows=shown.map((h,i)=>{
    const medal=i===0?'🥇':i===1?'🥈':i===2?'🥉':(i+1)+'.';
    const cls=i<3?'class="top"':'';
    return`<tr ${cls}><td>${medal}</td><td style="font-weight:${i<3?600:400}">${h.name||'Anónimo'}</td><td>${h.score}/14</td><td>${h.pct}%</td><td>${h.date}</td><td>${h.time}</td></tr>`;
  }).join('');
  el.innerHTML=`<div class="card-sm"><table>
    <thead><tr><th>#</th><th>Nome</th><th>Acertos</th><th>%</th><th>Data</th><th>Hora</th></tr></thead>
    <tbody>${rows}</tbody>
  </table></div>`;
}

showScreen('home');
loadRanking('home-rank',5);
</script>
