<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Quiz — Recrutamento e Seleção · UNISUAM</title>
<style>
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;background:#f4f2ee;min-height:100vh;color:#1a1a18;font-size:15px}
.page{max-width:720px;margin:0 auto;padding:1.5rem 1rem}
.screen{display:none}
.screen.active{display:block}
h1{font-size:24px;font-weight:600;color:#1a1a18;margin-bottom:.35rem}
h2{font-size:18px;font-weight:600;color:#1a1a18;margin-bottom:1rem}
p{font-size:14px;color:#5f5e5a;line-height:1.65}
.site-header{background:#fff;border-bottom:1px solid #e0ddd6;padding:.75rem 1.25rem;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:10}
.logo{font-size:14px;font-weight:600;color:#1a1a18;display:flex;align-items:center;gap:8px}
.logo-dot{width:9px;height:9px;border-radius:50%;background:#5434b7}
.nav-link{font-size:13px;color:#888780;cursor:pointer;padding:4px 10px;border-radius:6px;transition:background .15s}
.nav-link:hover,.nav-link.active{background:#eeedfe;color:#5434b7}
.card{background:#fff;border:1px solid #e0ddd6;border-radius:14px;padding:1.5rem}
.card-sm{background:#fff;border:1px solid #e0ddd6;border-radius:10px;padding:1rem 1.25rem}
.badge{display:inline-block;font-size:12px;padding:3px 10px;border-radius:6px;font-weight:500}
.badge-purple{background:#eeedfe;color:#3c3489}
.badge-green{background:#eaf3de;color:#27500a}
.badge-red{background:#fcebeb;color:#791f1f}
.badge-amber{background:#faeeda;color:#633806}
.badge-gray{background:#f1efe8;color:#444441}
.prog-wrap{height:6px;background:#e0ddd6;border-radius:4px;margin:1rem 0}
.prog-fill{height:100%;background:#5434b7;border-radius:4px;transition:width .3s}
.opt{display:flex;align-items:flex-start;gap:10px;padding:.8rem 1rem;border:1px solid #e0ddd6;border-radius:10px;cursor:pointer;margin-bottom:.5rem;font-size:14px;color:#1a1a18;line-height:1.55;transition:background .15s,border-color .15s;background:#fff}
.opt:hover{background:#f4f2ee;border-color:#b4b2a9}
.opt.correct{border-color:#639922;background:#eaf3de;color:#27500a}
.opt.wrong{border-color:#a32d2d;background:#fcebeb;color:#791f1f}
.opt.disabled{pointer-events:none}
.letter{flex-shrink:0;width:24px;height:24px;border-radius:50%;border:1px solid #d3d1c7;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:600;color:#888780}
.opt.correct .letter{border-color:#639922;background:#c0dd97;color:#27500a}
.opt.wrong .letter{border-color:#a32d2d;background:#f7c1c1;color:#791f1f}
.btn{display:inline-flex;align-items:center;gap:6px;padding:.6rem 1.25rem;border:1px solid #d3d1c7;border-radius:8px;font-size:14px;font-weight:500;cursor:pointer;background:#fff;color:#1a1a18;transition:background .15s;font-family:inherit}
.btn:hover{background:#f4f2ee}
.btn-primary{background:#5434b7;color:#fff;border-color:#5434b7}
.btn-primary:hover{background:#3c3489}
.btn-outline{background:transparent;color:#5434b7;border-color:#5434b7}
.btn-outline:hover{background:#eeedfe}
.expl{margin-top:.75rem;padding:.75rem 1rem;background:#f4f2ee;border-left:3px solid #5434b7;border-radius:0 8px 8px 0;font-size:13px;color:#444441;line-height:1.6;display:none}
.score-big{font-size:60px;font-weight:700;color:#1a1a18;text-align:center;line-height:1;margin:1rem 0 .25rem}
.score-sub{text-align:center;font-size:14px;color:#888780;margin-bottom:1.25rem}
.badges-row{display:flex;gap:8px;justify-content:center;flex-wrap:wrap;margin-bottom:1.5rem}
table{width:100%;border-collapse:collapse;font-size:13px}
th{text-align:left;padding:8px 10px;color:#888780;border-bottom:1px solid #e0ddd6;font-weight:500}
td{padding:8px 10px;border-bottom:1px solid #e0ddd6;color:#1a1a18}
tr:last-child td{border-bottom:none}
tr.top{background:#faeeda}
.stat-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(120px,1fr));gap:10px;margin-bottom:1.25rem}
.stat{background:#f4f2ee;border-radius:8px;padding:.8rem 1rem}
.stat-label{font-size:11px;color:#888780;margin-bottom:4px}
.stat-val{font-size:20px;font-weight:600;color:#1a1a18}
.hero{background:linear-gradient(135deg,#5434b7,#3c3489);border-radius:16px;padding:1.75rem;color:#fff;margin-bottom:1.25rem}
.hero h1{color:#fff;font-size:22px}
.hero p{color:rgba(255,255,255,.8);margin-top:.4rem;font-size:13px}
.hero-meta{display:flex;gap:8px;margin-top:1rem;flex-wrap:wrap}
.hero-tag{background:rgba(255,255,255,.18);color:#fff;font-size:11px;padding:3px 10px;border-radius:20px}
.empty{text-align:center;padding:2rem;color:#888780;font-size:13px}
.name-form{display:flex;flex-direction:column;gap:.75rem;margin-top:1rem}
.name-input{padding:.65rem 1rem;border:1px solid #d3d1c7;border-radius:8px;font-size:14px;font-family:inherit;color:#1a1a18;background:#fff;outline:none;transition:border-color .15s}
.name-input:focus{border-color:#5434b7}
.shared-note{font-size:11px;color:#888780;text-align:center;margin-top:.75rem;padding:.5rem;background:#f4f2ee;border-radius:6px}
</style>
</head>
<body>

<header class="site-header">
  <div class="logo"><span class="logo-dot"></span>Quiz RH · UNISUAM</div>
  <div style="display:flex;gap:4px">
    <span class="nav-link active" id="nav-home" onclick="showScreen('home')">Início</span>
    <span class="nav-link" id="nav-rank" onclick="goRanking()">Ranking</span>
  </div>
</header>

<div class="page">

  <!-- HOME -->
  <div id="home" class="screen active">
    <div class="hero">
      <h1>Recrutamento e Seleção</h1>
      <p>Módulo 2 · Curso de Tecnologia em Gestão de Recursos Humanos</p>
      <p style="margin-top:.2rem;font-size:12px;opacity:.65">Prof.ª Cátia Regina França de Sousa Gaião e Silva, DSc</p>
      <div class="hero-meta">
        <span class="hero-tag">35 questões no banco</span>
        <span class="hero-tag">14 por avaliação</span>
        <span class="hero-tag">Ranking partilhado 🌍</span>
      </div>
    </div>
    <div class="card-sm" style="margin-bottom:1rem">
      <p style="color:#1a1a18;font-weight:500;margin-bottom:.4rem">Como funciona</p>
      <p>Cada avaliação sorteia 14 questões aleatórias. O resultado é guardado no <strong style="color:#5434b7">ranking global</strong> — visível para todos os participantes.</p>
    </div>
    <div style="margin-bottom:1.5rem">
      <button class="btn btn-primary" onclick="askName()" style="font-size:15px;padding:.7rem 1.75rem">Iniciar avaliação →</button>
    </div>
    <div>
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:.75rem">
        <h2 style="margin-bottom:0">Ranking recente</h2>
        <span style="font-size:11px;color:#888780">🌍 visível para todos</span>
      </div>
      <div id="home-rank"><div style="color:#888780;font-size:13px;padding:.5rem 0">A carregar...</div></div>
    </div>
  </div>

  <!-- NAME -->
  <div id="name-screen" class="screen">
    <div class="card" style="max-width:400px;margin:2rem auto">
      <h2>Como te chamas?</h2>
      <p>O teu nome aparecerá no ranking global, visível para todos os participantes.</p>
      <div class="name-form">
        <input class="name-input" id="player-name" type="text" placeholder="Ex: Maria Silva" maxlength="30" onkeydown="if(event.key==='Enter')confirmName()">
        <button class="btn btn-primary" onclick="confirmName()">Começar →</button>
        <button class="btn" onclick="showScreen('home')">Cancelar</button>
      </div>
    </div>
  </div>

  <!-- QUIZ -->
  <div id="quiz" class="screen">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:.75rem;flex-wrap:wrap;gap:.5rem">
      <span class="badge badge-purple" id="q-label">Questão 1 / 14</span>
      <span class="badge badge-gray" id="q-topic"></span>
    </div>
    <div class="prog-wrap"><div class="prog-fill" id="prog" style="width:0%"></div></div>
    <div class="card" style="margin-bottom:1rem">
      <p id="q-text" style="font-size:15px;color:#1a1a18;font-weight:500;line-height:1.6"></p>
    </div>
    <div id="opts"></div>
    <div class="expl" id="q-expl"></div>
    <div style="display:flex;justify-content:space-between;align-items:center;margin-top:1.25rem">
      <div id="live-score" style="font-size:13px;color:#888780"></div>
      <button class="btn btn-primary" id="next-btn" style="display:none" onclick="nextQ()">Próxima →</button>
    </div>
  </div>

  <!-- RESULT -->
  <div id="result" class="screen">
    <h2>Resultado</h2>
    <div class="card" style="margin-bottom:1.25rem">
      <div class="score-big" id="score-num"></div>
      <div class="score-sub" id="score-msg"></div>
      <div class="badges-row">
        <span class="badge badge-green" id="b-acc"></span>
        <span class="badge badge-red" id="b-err"></span>
        <span class="badge badge-amber" id="b-pct"></span>
      </div>
      <div class="stat-grid">
        <div class="stat"><div class="stat-label">Acertos</div><div class="stat-val" id="st-acc" style="color:#3b6d11"></div></div>
        <div class="stat"><div class="stat-label">Erros</div><div class="stat-val" id="st-err" style="color:#a32d2d"></div></div>
        <div class="stat"><div class="stat-label">Aproveitamento</div><div class="stat-val" id="st-pct" style="color:#5434b7"></div></div>
      </div>
      <div id="save-status" style="font-size:13px;color:#888780;margin-bottom:1rem"></div>
      <div style="display:flex;gap:.5rem;flex-wrap:wrap">
        <button class="btn btn-primary" onclick="askName()">Nova tentativa →</button>
        <button class="btn btn-outline" onclick="goRanking()">Ver ranking</button>
        <button class="btn" onclick="showScreen('home')">Início</button>
      </div>
    </div>
    <h2>Top ranking</h2>
    <div id="result-rank"><div style="color:#888780;font-size:13px">A carregar...</div></div>
  </div>

  <!-- RANKING -->
  <div id="ranking" class="screen">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1rem;flex-wrap:wrap;gap:.5rem">
      <h2 style="margin-bottom:0">Ranking global 🌍</h2>
      <button class="btn" onclick="loadRanking('full-rank',50)" style="font-size:12px">↻ Atualizar</button>
    </div>
    <p style="margin-bottom:1rem">Resultados de todos os participantes, do melhor para o pior.</p>
    <div id="full-rank"><div style="color:#888780;font-size:13px">A carregar...</div></div>
    <div class="shared-note">🔒 Dados partilhados e visíveis para todos os participantes</div>
    <div style="margin-top:1rem">
      <button class="btn btn-primary" onclick="askName()">Nova avaliação →</button>
    </div>
  </div>

</div>

<script>
// ── FIREBASE CONFIG ──────────────────────────────────────────────
// Para o ranking funcionar em produção, substitua os valores abaixo
// pelos da SUA base de dados Firebase Realtime Database.
// Instruções: https://firebase.google.com/docs/web/setup
const FIREBASE_URL = "https://quiz-rh-unisuam-default-rtdb.firebaseio.com";

// ── QUESTÕES ────────────────────────────────────────────────────
const ALL_Q=[
{t:"Conceito de Recrutamento",q:"Segundo Marras (2000), agregar pessoas é atividade fundamental da estratégia de toda organização que procura aplicar o recrutamento e a seleção como parte de um mesmo processo. Como esse processo é denominado?",opts:["Provisão de recursos humanos","Avaliação de desempenho","Diagnóstico de clima organizacional","Gestão por competências"],ans:0,e:"Marras (2000) define esse processo conjunto como 'a provisão de recursos humanos'."},
{t:"Conceito de Recrutamento",q:"O recrutamento pode ser definido como um conjunto de técnicas e procedimentos cujo objetivo principal é:",opts:["Demitir funcionários com baixo desempenho","Atrair candidatos potencialmente qualificados e capazes de ocupar cargos","Elaborar o plano de cargos e salários","Realizar avaliações de desempenho periódicas"],ans:1,e:"O recrutamento visa atrair candidatos qualificados e capazes de ocupar cargos na organização."},
{t:"Conceito de Seleção",q:"A seleção é definida como a escolha da pessoa certa para o cargo certo, visando:",opts:["Reduzir custos operacionais da empresa","Manter ou aumentar a eficiência e o desempenho do pessoal","Eliminar cargos desnecessários","Automatizar processos de RH"],ans:1,e:"A seleção busca a pessoa mais adequada para manter ou aumentar a eficiência e o desempenho do pessoal."},
{t:"Recrutamento Interno",q:"No recrutamento interno, quem são os candidatos preferidos para preencher vagas e oportunidades?",opts:["Candidatos externos recrutados no mercado","Os colaboradores atuais da organização","Indicações de headhunters","Ex-funcionários"],ans:1,e:"No recrutamento interno, os colaboradores internos são os candidatos preferidos, podendo ser promovidos ou transferidos."},
{t:"Recrutamento Externo",q:"No recrutamento externo, as vagas são preenchidas por meio de:",opts:["Transferências internas","Promoções de colaboradores atuais","Admissão de candidatos externos","Contratação de estagiários já presentes na empresa"],ans:2,e:"O recrutamento externo recorre à admissão de candidatos de fora da organização."},
{t:"Responsabilidade de Linha",q:"Na seleção, cabe à Responsabilidade de Linha (gerentes/chefes/gestores):",opts:["Aplicar testes psicométricos e de personalidade","Verificar o arquivo de candidatos","Decidir quanto ao preenchimento do cargo e escolher os candidatos finais","Treinar gerentes em técnicas de entrevista"],ans:2,e:"A Responsabilidade de Linha inclui decidir sobre o preenchimento do cargo e escolher os candidatos finais."},
{t:"Função de Staff",q:"Qual das alternativas abaixo corresponde a uma atribuição da Função de Staff (Departamento de RH) no processo seletivo?",opts:["Emitir a solicitação de empregado","Decidir a aprovação ou rejeição dos candidatos","Desenvolver técnicas de seleção mais adequadas","Escolher os candidatos finais e encaminhá-los ao setor"],ans:2,e:"O RH (função de staff) é responsável por desenvolver técnicas de seleção e assessorar gerentes."},
{t:"Entrevistas de Seleção",q:"Nas entrevistas de seleção, quais aspectos são verificados pelo entrevistador?",opts:["Salário pretendido, disponibilidade e tempo de deslocamento","Qualificação, habilidades, potencial e motivação do candidato","Histórico escolar exclusivamente","Referências pessoais e familiares"],ans:1,e:"A entrevista verifica qualificação, habilidades, potencial e motivação do candidato ao cargo."},
{t:"Entrevistas de Seleção",q:"O Job Description, utilizado durante as entrevistas de seleção, é um documento que contém:",opts:["Apenas o salário e os benefícios ofertados","Título da vaga, responsabilidades, qualificações, benefícios, horário e modelo de trabalho","Somente as competências técnicas exigidas","O histórico de candidatos anteriores"],ans:1,e:"O Job Description reúne título da vaga, responsabilidades, qualificações, benefícios, horário e modelo de trabalho."},
{t:"Feedback",q:"Ao comunicar o resultado do processo seletivo, candidatos não selecionados devem ser:",opts:["Ignorados, pois a prioridade é o candidato selecionado","Notificados o mais cedo possível","Contatados somente se solicitarem retorno","Informados por e-mail automático sem explicações"],ans:1,e:"Boas práticas indicam que candidatos não selecionados devem ser notificados o mais cedo possível."},
{t:"Feedback",q:"Fornecer a candidatos não selecionados explicações objetivas e construtivas sobre as razões do insucesso indica:",opts:["Falta de profissionalismo do RH","Uma atitude de respeito e empatia que contribui para a imagem positiva da empresa","Que a empresa não tem critérios definidos","Que o candidato foi selecionado em segunda chamada"],ans:1,e:"Dar feedback construtivo demonstra respeito e empatia, fortalecendo a percepção positiva da empresa."},
{t:"Feedback",q:"Para que o feedback seja eficaz, é recomendado:",opts:["Realizá-lo em locais públicos para maior transparência","Focar apenas nos pontos negativos para não gerar complacência","Utilizar um local privado e calmo, mantendo-se emocionalmente neutro","Delegar o conteúdo da comunicação a outro colega"],ans:2,e:"O feedback ideal ocorre em local privado e calmo, com o comunicador emocionalmente neutro e direto."},
{t:"Feedback",q:"A comunicação assertiva no feedback significa:",opts:["Ser agressivo e impositivo para garantir clareza","Enviar a mensagem de forma clara, objetiva, aberta e transparente com delicadeza e sutileza","Evitar qualquer tipo de crítica para não desmotivar","Utilizar indiretas para suavizar a mensagem"],ans:1,e:"Assertividade é enviar a mensagem de forma clara, objetiva e transparente, sem ser mal-educado."},
{t:"Headhunter",q:"O que diferencia um headhunter de um recrutador tradicional?",opts:["O headhunter só atua em recrutamento interno","O headhunter realiza apenas triagem de currículos","O headhunter realiza busca ativa de profissionais, abordando inclusive os que já estão empregados","O headhunter representa os candidatos e não a empresa"],ans:2,e:"O headhunter faz busca ativa no mercado, abordando profissionais empregados, ao contrário do recrutador tradicional."},
{t:"Headhunter",q:"Na primeira etapa do processo de trabalho do headhunter, chamada de Briefing, o profissional:",opts:["Publica a vaga em portais de emprego","Entende a cultura da empresa, o desafio da área e o perfil exato que a vaga exige","Realiza as entrevistas finais com os candidatos","Negocia o salário com o candidato escolhido"],ans:1,e:"O Briefing é a etapa em que o headhunter compreende a cultura da empresa e o perfil exigido para a vaga."},
{t:"Headhunter",q:"O Jobhunter difere do headhunter pois:",opts:["O jobhunter trabalha apenas para empresas de grande porte","O jobhunter é quem busca ativamente uma oportunidade para si mesmo no mercado","O jobhunter só recruta candidatos para cargos operacionais","O jobhunter representa a empresa no processo seletivo"],ans:1,e:"O jobhunter é o profissional que está no mercado buscando uma oportunidade para si mesmo."},
{t:"Avaliação de Desempenho",q:"Uma das razões principais para avaliar o desempenho dos colaboradores é fornecer recompensas. Qual das opções abaixo representa corretamente esse uso?",opts:["Identificar candidatos para processos seletivos externos","Justificar aumentos salariais, promoções, transferências e demissões","Medir a satisfação do cliente com os serviços prestados","Elaborar o organograma da empresa"],ans:1,e:"A avaliação de desempenho é usada para justificar recompensas como aumentos, promoções e transferências."},
{t:"Avaliação de Desempenho",q:"A ausência de um sistema de medição de desempenho afeta negativamente as organizações porque:",opts:["Aumenta o número de contratações externas","Sem medição não se pode identificar problemas nem estabelecer prioridades","Reduz o número de colaboradores disponíveis","Impede a realização de treinamentos"],ans:1,e:"Sem um sistema de medição, não é possível identificar problemas adequadamente nem estabelecer prioridades."},
{t:"Avaliação de Desempenho",q:"Um ponto fraco comum no processo de avaliação de desempenho é:",opts:["Excesso de clareza nos critérios avaliados","Processo injusto ou tendencioso","Muita objetividade na definição de metas","Transparência excessiva com os avaliados"],ans:1,e:"Processos injustos ou tendenciosos são um dos pontos fracos mais comuns na avaliação de desempenho."},
{t:"Avaliação por Objetivos",q:"A avaliação de desempenho por objetivos e resultados envolve:",opts:["Apenas o RH definindo as metas sem envolver o colaborador","Líder e subordinado reunindo-se para criar metas e, ao término do período, verificar se foram cumpridas","Somente a avaliação comportamental do colaborador","A aplicação de testes psicométricos padronizados"],ans:1,e:"Na avaliação por objetivos, líder e subordinado criam metas juntos e depois verificam o cumprimento ao final do período."},
{t:"Avaliação por Competências",q:"Na avaliação de desempenho por competências, o colaborador é avaliado:",opts:["Apenas por seu desempenho técnico no cargo","Não apenas pelo desempenho no cargo, mas também por sua performance como membro da organização","Somente com base em seu tempo de empresa","Exclusivamente por métricas financeiras"],ans:1,e:"A avaliação por competências considera o desempenho no cargo e a performance do colaborador como membro da organização."},
{t:"CHA",q:"No mapa de competências CHA, a letra 'H' representa:",opts:["Honestidade, integridade e conduta ética","Habilidade — capacidade de transformar conhecimento em ação","Hierarquia e nível de autoridade do cargo","Histórico profissional e formação acadêmica"],ans:1,e:"'H' no CHA representa Habilidade: a capacidade de transformar conhecimento em ação."},
{t:"CHA",q:"O modelo de competências CHAVE expande o CHA tradicional acrescentando as letras V e E, que representam:",opts:["Versatilidade e Eficiência","Valores e Entorno (responsabilidade socioambiental e cidadania)","Visão e Estratégia","Velocidade e Excelência"],ans:1,e:"O modelo CHAVE adiciona V (Valores) e E (Entorno/responsabilidade socioambiental)."},
{t:"Três Habilidades",q:"A habilidade conceitual, necessária principalmente ao nível institucional (alta direção), é definida como:",opts:["A capacidade de usar procedimentos e técnicas de um campo de especialização","A capacidade de trabalhar com outras pessoas e motivá-las","A capacidade de coordenar e integrar todos os interesses e atividades de uma organização","A capacidade de operar máquinas e equipamentos"],ans:2,e:"A habilidade conceitual envolve coordenar e integrar todos os interesses e atividades da organização."},
{t:"Três Habilidades",q:"Qual habilidade é mais requerida no nível operacional (supervisão)?",opts:["Habilidade conceitual","Habilidade humana","Habilidade técnica","Habilidade estratégica"],ans:2,e:"No nível operacional, a habilidade técnica é predominante."},
{t:"TICs e RH",q:"Com a implementação das TICs, o RH transita de um modelo tradicional para um RH Estratégico. O que caracteriza o RH Estratégico?",opts:["Foco em tarefas manuais e burocracia","Atuação como parceiro estratégico do negócio, focado em desenvolvimento de capital humano","Concentração em folha de pagamento e controle de presença","Dependência de métodos convencionais como memorandos"],ans:1,e:"O RH Estratégico atua como parceiro de negócio focado em capital humano, talentos e cultura organizacional."},
{t:"TICs e RH",q:"O uso de analytics no RH possibilita:",opts:["Substituir completamente as entrevistas de seleção","Analisar desempenho, engajamento e rotatividade para antecipar necessidades","Eliminar a necessidade de avaliação de desempenho","Automatizar a demissão de colaboradores"],ans:1,e:"Analytics permite análise detalhada de desempenho e engajamento, auxiliando o RH a antecipar necessidades."},
